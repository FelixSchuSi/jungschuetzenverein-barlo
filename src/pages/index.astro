				bottomText="Bis dahin kannst du dir das in den Kalender eintragen:"
			/> -->
			<!-- <Festtagsprogramm /> -->
		</section>
		<section class="feature-card__section">
			<h2>Was gibt es auf Insta?</h2>
			<p>
				Folge uns auf Instagram @jungschuetzenvereinbarlo_ev_ um auf dem
				Laufenden zu bleiben!
