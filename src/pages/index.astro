			<InstaProfileEmbed />
		</section>
	</Container>
	<style>
		.feature-card__section {
			margin: var(--section-margin) auto;
			display: flex;
			flex-direction: column;
		}

		.feature-card__grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: var(--theme-grid-gap);
		}
		@media (max-width: 768px) {
			.feature-card__grid {
				grid-template-columns: 1fr;
			}
		}
		.osterdisco-flyer {
			/* width: 100%; */
			/* max-width: 400px; */
			align-self: center;
			max-height: 80vh;
			border-radius: var(--theme-shape-radius);
		}
		.osterdisco-side-by-side {
			display: flex;
			flex-direction: row;
			gap: 1rem;
			/* justify-content: space-between; */
			align-items: center;
			width: 100%;
		}

		.osterdisco-text {
			/* flex-grow: 2; */
			max-width: 600px;
		}
		.osterdisco-text > * {
			max-width: 600px;
		}

		@media (max-width: 768px) {
			.osterdisco-text {
				display: none;
			}
		}
	</style>

	<style is:global>
		.feature-card__section > iframe {
			align-self: center;
		}
	</style>
</Layout>
